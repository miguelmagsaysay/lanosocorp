# Set to "true" to show the under-maintenance page on all routes. Omit or use "false" for the live site.
MAINTENANCE_MODE=false

# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender in Resend (required for production; see README)
RESEND_FROM_EMAIL=

# Inbound routing for contact form notifications
CONTACT_EMAIL=info@lanosocorp.com

# Google Analytics 4 — https://analytics.google.com/
NEXT_PUBLIC_GA_ID=

# Optional: Google Maps → Share → “Embed a map” iframe src (contact page)
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=

